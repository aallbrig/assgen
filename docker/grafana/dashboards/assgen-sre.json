    },

    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 43},
      "id": 41,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{service_name=\"assgen-server\"} |= ``",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "assgen-server Logs",
      "type": "logs"
    },

    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 53},
      "id": 42,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
